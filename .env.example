# ===== The 5 Agents - Environment Variables (template) =====
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
# אין להעלות את קובץ .env ל-git!

# --- ראובן / כלל הסוכנים: מפתח ה-API של Anthropic ---
ANTHROPIC_API_KEY=

# --- חן (החוקרת): מפתח ל-API של חיפוש/מחקר (אופציונלי, בהמשך) ---
SEARCH_API_KEY=

# --- יובל (מעצב התמונות): מפתח ל-API ליצירת תמונות (אופציונלי, בהמשך) ---
IMAGE_API_KEY=
